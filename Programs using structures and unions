#include<stdio.h>
#include<string.h>
#define MAX_EMPLOYEES 10
#define MAX_NAME_LENGTH 50
typedef struct
{
   char name[MAX_NAME_LENGTH];
   int employeeid;
   float basicpay;
   float hra;
   float da;
   float deduction;
   float grosspay;
}employee;
void calculategrosspay(employee*employee)
{
   employee->hra=0.20*employee->basicpay;
   employee->da=0.50*employee->basicpay;
   employee->deduction=0.02*employee->basicpay;
   employee->grosspay=employee->basicpay+employee->hra+employee->da-employee->deduction;
}
void displayemployeedetails(employee employee)
{
   printf("employee name%s\n",employee.name);
   printf("employee id:%d\n",employee.employeeid);
   printf("basicpay:%.2f\n",employee.basicpay);
   printf("hra:%.2f\n",employee.hra);
   printf("da:%.2f",employee.da);
   printf("deduction:%.2f\n",employee.deduction);
   printf("gross pay:%.2f\n",employee.grosspay);
}
int main()
{
   employee employees[MAX_EMPLOYEES];
   int numemp;
   printf("enter number of employees(max %d):",MAX_EMPLOYEES);
   scanf("%d",&numemp);
   if(numemp>MAX_EMPLOYEES)
   {
      printf("error:not possible\n");
      return 1;
   }
   int i;
   for(i=0;i<numemp;i++)
   {
      printf("enter employee %d details:\n",i+1);
      printf("name:");
      scanf("%s",employees[i].name);
      printf("employee id:");
      scanf("%d",&employees[i].employeeid);
      printf("basicpay:");
      scanf("%f",&employees[i].basicpay);
      calculategrosspay(&employees[i]);
   }
   printf("\n employee details:\n");
   for(i=0;i<numemp;i++)
   {
      displayemployeedetails(employees[i]);
   }
   return 0;
}
