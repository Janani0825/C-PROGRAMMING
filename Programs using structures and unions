#include<stdio.h>
struct bankaccount
{
   int accountnumber;
   char accountholdername[50];
   float balance;
};
void addaccount(struct bankaccount accounts[],int*n);
void displayaccount(struct bankaccount accounts[],int n);
void depositmoney(struct bankaccount accounts[],int n);
void withdrawmoney(struct bankaccount accounts[],int n);
#include"bankhead.h"
void addaccount(struct bankaccount accounts[],int*n)
{
   printf("enter account number: ");
   scanf("%d",&accounts[*n].accountnumber);
   printf("enter account holdername: ");
   scanf("%s",&accounts[*n].accountholdername);
   printf("enter initial balance");
   scanf("%f",&accounts[*n].balance);
   (*n)++;
}
void displayaccount(struct bankaccount accounts[],int n)
{
   int i;
   printf("account details: \n");
   for(i=0;i<n;i++)
   {
      printf("account number:%d\n",accounts[i].accountnumber);
      printf("account holdername:%s\n",accounts[i].accountholdername);
      printf("balance:%.2f\n",accounts[i].balance);
   }
}
void depositmoney(struct bankaccount accounts[],int n)
{
   int i,accountnumber;
   float amount;
   printf("enter account number: ");
   scanf("%d",&accountnumber);
   printf("enter amount to deposit: ");
   scanf("%f",&amount);
   for(i=0;i<n;i++)
   {
      if(accounts[i].accountnumber==accountnumber)
      {
         accounts[i].balance+=amount;
         printf("deposit succesful.new balance:%.2f\n",accounts[i].balance);
         return;
      }
   }
   printf("account not found");
}
void withdrawmoney(struct bankaccount accounts[],int n)
{
   int i;
   int accountnumber;
   float amount;
   printf("enter account number");
   scanf("%d",&accountnumber);
   printf("enter amount to withdraw:");
   scanf("%f",&amount);
   for(i=0;i<n;i++)
   {
      if(accounts[i].accountnumber==accountnumber)
      {
         if(accounts[i].balance>=amount)
         {
            accounts[i].balance-=amount;
            printf("withdraw successful.new balance:%.2f\n",accounts[i].balance);
         }
         else
         {
            printf("insufficient balance");
         }
         return ;
      }
   }
   printf("account not found\n");
}
int main()
{
   struct bankaccount accounts[100];
   int n=0;
   while(1)
   {
      printf("bank account management system\n");
      printf("1.add a new account\n");
      printf("2.display all accounts\n");
      printf("3.deposit money\n");
      printf("4.withdraw money\n");
      printf("5.exit\n");
      printf("enter your choice");
      int choice;
      scanf("%d",&choice);
      switch(choice)
      {
         case 1:
            addaccount(accounts,&n);
            break;
         case 2:
            displayaccount(accounts,n);
            break;
         case 3:
            depositmoney(accounts,n);
            break;
         case 4:
            withdrawmoney(accounts,n);
            break;
         case 5:
            return 0;
         default:
            printf("invalid choice,please try again\n");
      }
   }
   return 0;
}

