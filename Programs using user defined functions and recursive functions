#include"stronghead.h"
int factorial(int);
int strong(int n)
{
   int x,sum=0;
   while(n>0)
   {
      x=n%10;
      sum=sum+factorial(x);
      n=(n/10);

   }
   return sum;

}
factorial(int f)
{
   if(f==0||f==1)
      return 1;
   else
      return f*factorial(f-1);
}
int main()
{
   int n;
   printf("Enter a number");
   scanf("%d",&n);
   if(strong(n)==n)
      printf("The number is strong");
   else
      printf("Not strong");
   return 0;
}
