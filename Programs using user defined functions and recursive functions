#include<stdio.h>
void swap(int,int); //HEADER FILE
#include"swaphead.h"
void swap(int a,int b)
{
   int temp;
   temp=a;
   a=b;
   b=temp;
   printf("swapped numbers %d %d",a,b);
}
int main()
{
   int a,b;
   printf("enter two number");
   scanf("%d %d",&a,&b);
   printf("\nbefore swapping:%d %d ",a,b);
   swap(a,b);
   return 0;
}
