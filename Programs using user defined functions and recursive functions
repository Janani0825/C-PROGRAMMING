#include<stdio.h>
int countdigits(int num); //HEADER FILE
#include"counthead.h"
int countdigit(int num)
{
   int count=0;
   while (num!=0)
   {
      num/=10;
      count++;
   }
   return count;
}
int main()
{
   int number,digitcount;
   printf("Enter an integer:");
   scanf("%d",&number);
   digitcount=countdigit(number);
   printf("No of digits:%d",digitcount);
   return 0;
}
