#include<stdio.h>
int main()
{
   int number,factorial=1,i;
   printf("enter a number");
   scanf("%d",&number);
   if (number<0)
   {
      printf("factorial is not defined for negative number/n");
   }
   else
   {
      for(i=1;i<=number;i++)
      {
         factorial*=i;
      }
      printf("factorial of %d is %d/n",number,factorial);
   }
   return 0;
}



