#include<stdio.h>
int main()
{
   int decimal,binary=0,place=1,remainder;


   printf("enter a decimel number");
   scanf("%d",&decimal );
   while(decimal>0)
   {
      remainder=decimal%2;
     binary+=remainder*place;
     decimal/=2;
     place*=10

   }

   printf("binary number is:%d ",binary);

return 0;
}
