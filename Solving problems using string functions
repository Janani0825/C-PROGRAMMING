#include<stdio.h>
#include<string.h>
#include"palinhead.h"
int ispalindrome(const char *str)
{
   int len,i;
   len=strlen(str);
   for(i=0;i<len/2;i++)
   {
      if(str[i]!=str[len-i-1])
      {
         return 0;
      }
   }
   return 1;
}
int main()
{
   char str[100];
   printf("\nenter a string : ");
   scanf("%s",str);
   if(ispalindrome(str))
   {
      printf("%s is a palindrome.\n",str);
   }
   else
   {
      printf("%s is a not palindrome.\n",str);
   }
   return 0;
}
