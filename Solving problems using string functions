#include<stdio.h>
int findlocation(char str[],char ch);
int ischarpresent(char str[],char ch);
int countoccur(char str[],char ch);
#include"locathead.h"
int findlocation(char str[],char ch)
{
   int i;
   for(i=0;str[i]!='\0';i++)
   {
      if(str[i]==ch)
         return i;
   }
   return -1;
}
int ischaracterpresent(char str[],char ch)
{
   int i;
   for(i=0;str[i]!='\0';i++)
   {
      if(str[i]==ch)
         return-1;
   }
   return 0;
}
int countoccur(char str[],char ch)
{
   int count=0,i;
   for(i=0;str[i]!='\0';i++)
   {
      if(str[i]==ch)
         count++;
   }
   return count;
}
int main()
{
   int location,occurences;
   char ch;
   char str[100];
   printf("\n enter a string : ");
   scanf("%s",&str);
   printf("\n enter a character to be searched: ");
   scanf("\n%c",&ch);
   location=findlocation(str,ch);
   if(location!=-1)
   {
      printf("\nThe character '%c' is found at index %d.",ch,location+1);
   }
   else
   {
      printf("\n The character '%c' is not found in the string.",ch);
   }
   if(ischaracterpresent(str,ch))
   {
      printf("\n The character '%c' is present in the string.",ch);
   }
   else
   {
      printf("\n The character '%c' is not present in the string.",ch);
   }
   occurences=(countoccur(str,ch));

         printf("\nThe character '%c' appears %d times in the string.\n",ch,occurences);

         return 0;
}
