#include<stdio.h>
#include<string.h>
#include<ctype.h>
#include"upperhead.h"
void touppercase(char str[])
{
   int i=0;
   while(str[i]!='\0')
   {
      if(str[i]>='a'&& str[i]<='z')
      {
         str[i]=str[i]-32;
      }
      else if(str[i]>='A'&& str[i]<='Z')
      {
         str[i]=str[i]+32;
      }
      else
      {
         printf("\n invalide statement.\n");
      }
      i++;
   }
}
int main()
{
   char str[100];
   printf("\n enter a string: ");
   fgets(str,sizeof(str),stdin);
   str[strcspn(str,"\n")]=0;
   touppercase(str);
   printf("uppercase string: %s\n",str);
   return 0;
}

