   {
    for(j=0;j<c;j++)
    {
       scanf("%d",&matrix[i][j]);
    }
   }
}
 void multiplymatrices(int matrix1[10][10],int matrix2[10][10],int result [10][10],int r1,int c1,int c2)
 {
    int i,j,k;
    for(i=0;i<r1;i++)
    {
       for(j=0;j<c2;j++)
       {
          result[i][j]=0;
          for (k=0;k<c1;k++)
          {
             result[i][j]+=matrix1[i][k]*matrix2[k][j];
          }
       }
    }
 }
void transposematrix(int matrix[10][10],int transpose[10][10],int r,int c)
{
   int i,j;
   for(i=0;i<r;i++)
   {
      for(j=0;j<c;j++)
      {
        transpose[j][i]=matrix[i][j];
      }
   }
}
